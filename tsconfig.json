{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "baseUrl": "./", /* Base directory to resolve non-absolute module names. */
    "paths": {
      "@db/*": ["src/db/*"],
      "@components/*": ["src/components/*"],
      "@navigators/*": ["src/navigators/*"],
      "@styles/*": ["src/styles/*"],
      "@store/*": ["src/store/*"],
    },
  },
  "extends": "expo/tsconfig.base"
}
